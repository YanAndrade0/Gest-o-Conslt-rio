# --- STRIPE API (Back-end) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- CONFIGURAÇÃO DOS PREÇOS (dashboard.stripe.com/products) ---
# ATENÇÃO: Use o "API ID" do PREÇO (começa com price_), NÃO o do Produto (prod_).

# ID do Preço Mensal (Exemplo: price_1Qxyz...)
VITE_STRIPE_MONTHLY_PRICE_ID=

# ID do Preço Anual (Exemplo: price_1Qabc...)
VITE_STRIPE_YEARLY_PRICE_ID=

# --- FIREBASE ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
