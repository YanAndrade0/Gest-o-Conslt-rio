# ------------------------------------------------------------------------------
# CONFIGURAÇÕES DO STRIPE (AI Studio > Menu Settings / Engrenagem)
# ------------------------------------------------------------------------------

# 1. Chave Secreta (Back-end) - Começa com sk_test_ ou sk_live_
STRIPE_SECRET_KEY=

# 2. Chaves Públicas e IDs (Front-end)
VITE_STRIPE_PUBLISHABLE_KEY=

# ID do Plano Mensal (Começa com price_...)
VITE_STRIPE_MONTHLY_PRICE_ID=

# ID do Plano Anual (Começa com price_...)
VITE_STRIPE_YEARLY_PRICE_ID=

# 3. Webhook (Opcional para testes)
STRIPE_WEBHOOK_SECRET=
