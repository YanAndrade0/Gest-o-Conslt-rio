# ------------------------------------------------------------------------------
# CONFIGURAÇÕES DO MERCADO PAGO (AI Studio > Menu Settings / Engrenagem)
# ------------------------------------------------------------------------------

# 1. Access Token do Back-end (Começa com APP_USR-...)
MERCADOPAGO_ACCESS_TOKEN=

# 2. Chave Pública do Front-end (Começa com APP_USR-...)
VITE_MERCADOPAGO_PUBLIC_KEY=

# 3. IDs dos Planos (Pre-approval Plan IDs ou Títulos)
VITE_MP_PLAN_MONTHLY_ID=
VITE_MP_PLAN_YEARLY_ID=
