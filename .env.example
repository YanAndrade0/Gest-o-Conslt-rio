# Stripe API Keys (Secretas - Configurar no menu Settings)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Public Keys (Client side)
VITE_STRIPE_PUBLISHABLE_KEY=

# IDs de Preço do Stripe (Obtenha no Dashboard do Stripe > Catálogo de Produtos)
# Exemplo: price_1Hh...
VITE_STRIPE_MONTHLY_PRICE_ID=
VITE_STRIPE_YEARLY_PRICE_ID=
