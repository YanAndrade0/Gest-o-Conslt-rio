rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ---------------------------------------------------------
    // Phase 0: Default Deny
    // ---------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // ---------------------------------------------------------
    // HELPERS
    // ---------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Auth tokens in this environment don't have custom claims
    // We must look up the user doc. This is the "Master Gate".
    function getUserData() {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userPath) ? get(userPath).data : null;
    }

    function getClinicData(clinicId) {
      let clinicPath = /databases/$(database)/documents/clinics/$(clinicId);
      return exists(clinicPath) ? get(clinicPath).data : null;
    }

    function isClinicActive(clinicId) {
      let clinic = getClinicData(clinicId);
      return clinic != null && (
        clinic.get(['subscription', 'status'], 'inactive') == 'active' 
        || (clinic.get('trialEndsAt', '') != '' && request.time < timestamp(clinic.trialEndsAt))
      );
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isMasterAdmin() {
      return isSignedIn() && request.auth.token.email == 'yandatafox@gmail.com';
    }

    function isClinicOwner(clinicId) {
      let userData = getUserData();
      return isSignedIn() && userData != null && userData.get('clinicId', '') == clinicId && userData.get('role', '') == 'owner';
    }

    function isClinicSecretary(clinicId) {
      let userData = getUserData();
      return isSignedIn() && userData != null && userData.get('clinicId', '') == clinicId && userData.get('role', '') == 'secretary';
    }

    function isClinicMember(clinicId) {
      let userData = getUserData();
      return isSignedIn() && userData != null && userData.get('clinicId', '') == clinicId;
    }

    function isVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.firebase.sign_in_provider == 'google.com');
    }

    // ---------------------------------------------------------
    // VALIDATION HELPERS
    // ---------------------------------------------------------
    function isValidUser(data) {
      return data.uid == request.auth.uid
        && (data.displayName == null || (data.displayName is string && data.displayName.size() <= 100))
        && (data.email == null || (data.email is string && data.email.size() <= 100))
        && data.keys().hasAll(['uid', 'role']);
    }

    function isClinicUnlimited(clinicData) {
      return clinicData.get('unlimitedUsers', false) == true || 
             clinicData.name == "Andrade Odontologia" ||
             clinicData.name == "Andrade Odontologia "; // Case sensitive and common variants
    }

    function canAddMoreUsers(clinicId) {
      let clinic = get(/databases/$(database)/documents/clinics/$(clinicId)).data;
      return isClinicUnlimited(clinic) || clinic.userCount < 5;
    }

    function isValidClinic(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.ownerId == request.auth.uid
        && data.accessCode is string && data.accessCode.size() == 6
        && data.userCount is int && data.userCount >= 1 && (isClinicUnlimited(data) || data.userCount <= 5)
        && data.keys().hasAll(['name', 'ownerId', 'accessCode', 'userCount']);
    }

    function isValidPatient(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.clinicId is string && isValidId(data.clinicId)
        && data.keys().hasAll(['name', 'clinicId']);
    }

    function isValidAppointment(data) {
      return data.patientId is string && isValidId(data.patientId)
        && data.date is string && data.date.size() <= 50
        && data.clinicId is string && isValidId(data.clinicId)
        && data.keys().hasAll(['patientId', 'date', 'clinicId']);
    }

    function isValidEvolution(data) {
      return data.patientId is string && isValidId(data.patientId)
        && data.description is string && data.description.size() <= 10000
        && data.clinicId is string && isValidId(data.clinicId)
        && data.keys().hasAll(['patientId', 'description', 'date', 'clinicId']);
    }

    function isValidTransaction(data) {
      return data.type in ['receita', 'despesa']
        && data.amount is number
        && data.date is string
        && data.clinicId is string && isValidId(data.clinicId)
        && data.keys().hasAll(['type', 'amount', 'date', 'clinicId']);
    }

    function isValidAuditLog(data) {
      return data.userId == request.auth.uid
        && data.action is string
        && data.clinicId is string && isValidId(data.clinicId)
        && data.timestamp is string
        && data.keys().hasAll(['userId', 'action', 'timestamp', 'clinicId']);
    }

    function isValidOdontogram(data) {
      return data.patientId is string && isValidId(data.patientId)
        && data.clinicId is string && isValidId(data.clinicId)
        && data.teeth is map
        && data.keys().hasAll(['patientId', 'clinicId', 'teeth']);
    }

    function isValidAnamnesis(data) {
      return data.patientId is string && isValidId(data.patientId)
        && data.clinicId is string && isValidId(data.clinicId)
        && data.questions is map
        && data.keys().hasAll(['patientId', 'clinicId', 'questions']);
    }

    // ---------------------------------------------------------
    // ENTITIES
    // ---------------------------------------------------------

    // Users
    match /users/{userId} {
      allow list: if isSignedIn() && resource.data.clinicId == getUserData().clinicId;
      allow read: if isSignedIn(); // Allow reading profiles for collaboration
      allow create: if isVerified() && request.auth.uid == userId && isValidUser(incoming())
        && canAddMoreUsers(incoming().clinicId);
      allow update: if isVerified() && request.auth.uid == userId 
        && isValidUser(incoming())
        && (incoming().role == existing().role || isClinicOwner(existing().clinicId)); 
    }

    // Clinics
    match /clinics/{clinicId} {
      allow read: if isSignedIn();
      allow list: if isSignedIn(); 
      allow create: if isVerified() && isValidClinic(incoming());
      allow update: if isVerified() && (
        isClinicOwner(clinicId) || 
        isMasterAdmin() ||
        (
          // Action: Join - allows incrementing userCount by 1
          incoming().diff(existing()).affectedKeys().hasOnly(['userCount', 'updatedAt']) &&
          incoming().userCount == existing().userCount + 1 &&
          (isClinicUnlimited(existing()) || existing().userCount < 5)
        )
      );
    }

    // Patients
    match /patients/{patientId} {
      allow list: if isSignedIn() && resource.data.clinicId == getUserData().clinicId;
      allow get: if isSignedIn() && isClinicMember(existing().clinicId);
      allow create: if isVerified() && isClinicMember(incoming().clinicId) && isClinicActive(incoming().clinicId) && isValidPatient(incoming());
      allow update: if isVerified() && isClinicMember(existing().clinicId) && isClinicActive(existing().clinicId) && isValidPatient(incoming());
      allow delete: if isVerified() && isClinicOwner(existing().clinicId) && isClinicActive(existing().clinicId);
    }

    // Appointments
    match /appointments/{appointmentId} {
      allow list: if isSignedIn() && getUserData() != null
        && resource.data.clinicId == getUserData().clinicId
        && (getUserData().get('role', '') in ['owner', 'secretary'] || resource.data.get('doctorName', '') == getUserData().get('displayName', ''));
      allow get: if isSignedIn() && isClinicMember(existing().clinicId)
        && (getUserData().get('role', '') in ['owner', 'secretary'] || existing().get('doctorName', '') == getUserData().get('displayName', ''));
      allow create: if isVerified() && isClinicMember(incoming().clinicId) && isClinicActive(incoming().clinicId) && isValidAppointment(incoming());
      allow update: if isVerified() && isClinicMember(existing().clinicId) && isClinicActive(existing().clinicId) && isValidAppointment(incoming());
      allow delete: if isVerified() && isClinicMember(existing().clinicId) && isClinicActive(existing().clinicId);
    }

    // Evolutions
    match /evolutions/{evolutionId} {
      allow list: if isSignedIn() && resource.data.clinicId == getUserData().clinicId;
      allow get: if isSignedIn() && isClinicMember(existing().clinicId);
      allow create: if isVerified() && isClinicMember(incoming().clinicId) && isClinicActive(incoming().clinicId) && isValidEvolution(incoming());
      allow update: if isVerified() && isClinicMember(existing().clinicId) && isClinicActive(existing().clinicId) && isValidEvolution(incoming());
      allow delete: if isVerified() && isClinicMember(existing().clinicId) && isClinicActive(existing().clinicId);
    }

    // Odontograms
    match /odontograms/{odontogramId} {
      allow list: if isSignedIn() && resource.data.clinicId == getUserData().clinicId;
      allow get: if isSignedIn() && isClinicMember(existing().clinicId);
      allow create: if isVerified() && isClinicMember(incoming().clinicId) && isClinicActive(incoming().clinicId) && isValidOdontogram(incoming());
      allow update: if isVerified() && isClinicMember(existing().clinicId) && isClinicActive(existing().clinicId) && isValidOdontogram(incoming());
    }

    // Anamneses
    match /anamneses/{anamnesisId} {
      allow list: if isSignedIn() && resource.data.clinicId == getUserData().clinicId;
      allow get: if isSignedIn() && isClinicMember(existing().clinicId);
      allow create: if isVerified() && isClinicMember(incoming().clinicId) && isClinicActive(incoming().clinicId) && isValidAnamnesis(incoming());
      allow update: if isVerified() && isClinicMember(existing().clinicId) && isClinicActive(existing().clinicId) && isValidAnamnesis(incoming());
    }

    // Patient Photos
    match /patientPhotos/{photoId} {
      allow list: if isSignedIn() && resource.data.clinicId == getUserData().clinicId;
      allow get: if isSignedIn() && isClinicMember(existing().clinicId);
      allow create: if isVerified() && isClinicMember(incoming().clinicId);
      allow update: if isVerified() && isClinicMember(existing().clinicId);
      allow delete: if isVerified() && isClinicMember(existing().clinicId);
    }

    // Transactions
    match /transactions/{transactionId} {
      allow list: if isSignedIn() && resource.data.clinicId == getUserData().clinicId;
      allow get: if isSignedIn() && isClinicMember(existing().clinicId);
      allow create: if isVerified() && isClinicMember(incoming().clinicId) && isClinicActive(incoming().clinicId) && isValidTransaction(incoming());
      allow update: if isVerified() && isClinicOwner(existing().clinicId) && isClinicActive(existing().clinicId) && isValidTransaction(incoming());
      allow delete: if isVerified() && isClinicOwner(existing().clinicId) && isClinicActive(existing().clinicId);
    }

    // Settings
    match /settings/{settingId} {
      allow read: if isSignedIn() && isClinicMember(existing().clinicId);
      allow write: if isVerified() && isClinicOwner(incoming().clinicId || existing().clinicId);
    }

    // Audit Logs (Write Only, Immutable)
    match /auditLogs/{logId} {
      allow list: if isVerified() && isClinicOwner(getUserData().clinicId);
      allow create: if isVerified() && isClinicMember(incoming().clinicId) && isValidAuditLog(incoming());
      allow read, update, delete: if false; 
    }

    // Licenses
    match /licenseCodes/{licenseId} {
      allow read: if isSignedIn();
      allow create: if false; 
    }
  }
}
